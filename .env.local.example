# Database Configuration

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blockchain-voting?retryWrites=true&w=majority

# NextAuth Configuration
# Generate a secure random string for NextAuth secret (e.g., using `openssl rand -base64 32`)
NEXTAUTH_SECRET=generate_a_secure_random_string_for_production
NEXTAUTH_URL=http://localhost:3000

# Web3 Configuration
# Optional: You can add these if you're connecting to specific blockchain networks
# NEXT_PUBLIC_RPC_URL=https://mainnet.infura.io/v3/your_infura_id
# NEXT_PUBLIC_CHAIN_ID=1  # Ethereum Mainnet

# WalletConnect Configuration
# Get your project ID from https://cloud.walletconnect.com/sign-in
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: For production deployments
# NODE_ENV=production   